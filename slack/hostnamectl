#!/usr/bin/env bash
#
# hostnamectl - Slackware-compatible hostnamed client
# Clean implementation with safe parsing and stable output
#

DBUS_DEST="org.freedesktop.hostname1"
DBUS_PATH="/org/freedesktop/hostname1"
DBUS_IFACE="org.freedesktop.hostname1"

HOSTNAME_FILE="/etc/HOSTNAME"
[ -f /etc/hostname ] && HOSTNAME_FILE="/etc/hostname"

MACHINE_INFO="/etc/machine-info"

VALID_CHASSIS="desktop laptop server tablet handset watch embedded vm container"

# ─────────────────────────────────────────────
# helpers
# ─────────────────────────────────────────────

die() {
  echo "hostnamectl: $*" >&2
  exit 1
}

require_root() {
  [ "$EUID" -ne 0 ] && die "must be root"
}

trim() {
  tr -d '[:space:]'
}

# ─────────────────────────────────────────────
# machine-info
# ─────────────────────────────────────────────

mi_get() {
  [ -f "$MACHINE_INFO" ] || return
  grep "^$1=" "$MACHINE_INFO" 2>/dev/null | cut -d= -f2- | tr -d '"'
}

mi_set() {
  require_root
  touch "$MACHINE_INFO" 2>/dev/null || die "cannot write /etc/machine-info"

  if grep -q "^$1=" "$MACHINE_INFO" 2>/dev/null; then
    sed -i "s|^$1=.*|$1=\"$2\"|" "$MACHINE_INFO"
  else
    echo "$1=\"$2\"" >> "$MACHINE_INFO"
  fi
}

# ─────────────────────────────────────────────
# DMI helpers
# ─────────────────────────────────────────────

dmi() {
  cat "/sys/class/dmi/id/$1" 2>/dev/null
}

# ─────────────────────────────────────────────
# chassis detection (FIXED)
# ─────────────────────────────────────────────

detect_chassis() {
  local c vendor

  c=$(mi_get CHASSIS)
  [ -n "$c" ] && { echo "$c"; return; }

  c=$(dmi chassis_type)

  case "$c" in
    3|4|5|6|7)  echo "desktop"; return ;;
    8|9|10|14)  echo "laptop"; return ;;
    11)         echo "handset"; return ;;
    13|31|32)   echo "server"; return ;;
  esac

  vendor=$(dmi sys_vendor | tr 'A-Z' 'a-z')

  case "$vendor" in
    *hp*|*dell*|*lenovo*|*asus*|*acer*)
      echo "desktop"
      return
    ;;
  esac

  echo "unknown"
}

# ─────────────────────────────────────────────
# virtualization
# ─────────────────────────────────────────────

detect_virtualization() {
  grep -q container /proc/1/cgroup 2>/dev/null && { echo "container"; return; }
  grep -qi hypervisor /proc/cpuinfo 2>/dev/null && { echo "vm"; return; }
  echo "none"
}

# ─────────────────────────────────────────────
# OS info
# ─────────────────────────────────────────────

os_pretty() {
  [ -f /etc/os-release ] && . /etc/os-release && echo "$PRETTY_NAME" && return
  echo "Unknown OS"
}

os_cpe() {
  [ -f /etc/os-release ] && grep ^CPE_NAME= /etc/os-release | cut -d= -f2- | tr -d '"'
}

# ─────────────────────────────────────────────
# DBus fallback (optional)
# ─────────────────────────────────────────────

dbus_call() {
  command -v dbus-send >/dev/null 2>&1 || return 1

  dbus-send --system --print-reply \
    --dest="$DBUS_DEST" "$DBUS_PATH" \
    "$DBUS_IFACE.$1" \
    "string:$2" "boolean:false" >/dev/null 2>&1
}

# ─────────────────────────────────────────────
# status output
# ─────────────────────────────────────────────

cmd_status() {
  local static transient icon chassis machine_id boot_id
  local vendor model fw_ver fw_date kernel arch os cpe

  static=$(tr -d '[:space:]' < "$HOSTNAME_FILE" 2>/dev/null)
  [ -z "$static" ] && static="n/a"

  transient=$(hostname 2>/dev/null)
  [ -z "$transient" ] && transient="n/a"

  icon=$(mi_get ICON_NAME)
  [ -z "$icon" ] && icon="computer"

  chassis=$(detect_chassis)

  machine_id=$(tr -d '[:space:]' < /etc/machine-id 2>/dev/null)
  [ -z "$machine_id" ] && machine_id="n/a"

  # ✅ FIXED BOOT ID (your requested version)
  boot_id=$(tr -d '\n' < /proc/sys/kernel/random/boot_id 2>/dev/null)
  [ -z "$boot_id" ] && boot_id="n/a"

  vendor=$(dmi sys_vendor)
  model=$(dmi product_name)
  fw_ver=$(dmi bios_version)
  fw_date=$(dmi bios_date)

  kernel=$(uname -r)
  arch=$(uname -m)

  os=$(os_pretty)
  cpe=$(os_cpe)

  printf "   Static hostname: %s\n" "$static"
  [ "$transient" != "$static" ] && printf "Transient hostname: %s\n" "$transient"
  printf "         Icon name: %s\n" "$icon"
  printf "           Chassis: %s\n" "$chassis"
  printf "        Machine ID: %s\n" "$machine_id"
  printf "           Boot ID: %s\n" "$boot_id"

  printf "  Operating System: %s\n" "$os"
  [ -n "$cpe" ] && printf "            CPE OS: %s\n" "$cpe"

  printf "   Hardware Vendor: %s\n" "$vendor"
  printf "    Hardware Model: %s\n" "$model"
  printf "  Firmware Version: %s\n" "$fw_ver"
  printf "     Firmware Date: %s\n" "$fw_date"

  printf "            Kernel: Linux %s\n" "$kernel"
  printf "      Architecture: %s\n" "$arch"
}

# ─────────────────────────────────────────────
# hostname validation
# ─────────────────────────────────────────────

valid_hostname() {
  echo "$1" | grep -Eq '^[a-zA-Z0-9]([a-zA-Z0-9-]{0,61}[a-zA-Z0-9])?$'
}

# ─────────────────────────────────────────────
# set hostname
# ─────────────────────────────────────────────

cmd_set_hostname() {
  require_root

  name="$1"
  [ -z "$name" ] && die "missing hostname"

  valid_hostname "$name" || die "invalid hostname '$name'"

  dbus_call SetStaticHostname "$name" || echo "$name" > "$HOSTNAME_FILE"
  hostname "$name" 2>/dev/null

  echo "Hostname set to '$name'"
}

# ─────────────────────────────────────────────
# main
# ─────────────────────────────────────────────

case "${1:-status}" in
  status) cmd_status ;;
  set-hostname) shift; cmd_set_hostname "$@" ;;
  *) die "unknown command" ;;
esac
