#: data/org.freedesktop.hostname1.policy:9
msgid "Set the transient host name"
msgstr "Establecer el nombre de host transitorio"

#: data/org.freedesktop.hostname1.policy:10
msgid "Authentication is required to set the transient host name."
msgstr "Se requiere autenticación para establecer el nombre de host transitorio."

#: data/org.freedesktop.hostname1.policy:22
msgid "Set the static host name"
msgstr "Establecer el nombre de host estático"

#: data/org.freedesktop.hostname1.policy:23
msgid "Authentication is required to set the static host name."
msgstr "Se requiere autenticación para establecer el nombre de host estático."

#: data/org.freedesktop.hostname1.policy:32
msgid "Set machine information (pretty name, icon, chassis)"
msgstr "Establecer la información del equipo (nombre visible, icono, chasis)"

#: data/org.freedesktop.hostname1.policy:33
msgid "Authentication is required to set machine information."
msgstr "Se requiere autenticación para establecer la información del equipo."

#: data/org.freedesktop.hostname1.policy:42
msgid "Get the hardware product UUID"
msgstr "Obtener el UUID del producto de hardware"

#: data/org.freedesktop.hostname1.policy:43
msgid "Authentication is required to read the hardware product UUID."
msgstr "Se requiere autenticación para leer el UUID del producto de hardware."

#: data/org.freedesktop.hostname1.policy:52
msgid "Get the hardware serial number"
msgstr "Obtener el número de serie del hardware"

#: data/org.freedesktop.hostname1.policy:53
msgid "Authentication is required to read the hardware serial number."
msgstr "Se requiere autenticación para leer el número de serie del hardware."
