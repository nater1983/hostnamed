#!/bin/bash
#
# localectl - control the system locale and keyboard layout
# Bash implementation for systems using blocaled without systemd.
#
# Copyright 2025, GPLv2+

DBUS_DEST="org.freedesktop.locale1"
DBUS_PATH="/org/freedesktop/locale1"
DBUS_IFACE="org.freedesktop.locale1"

die() {
  echo "localectl: $*" >&2
  exit 1
}

need_busctl() {
  command -v busctl &>/dev/null || die "busctl not found"
}

get_property() {
  busctl get-property "$DBUS_DEST" "$DBUS_PATH" "$DBUS_IFACE" "$1" 2>/dev/null
}

get_string() {
  get_property "$1" | cut -d' ' -f2- | tr -d '"'
}

get_strarray() {
  # returns "as N val1 val2 ..." — join into readable form
  get_property "$1" | sed 's/^as [0-9]* //' | tr -d '"' | tr ' ' '\n' | grep -v '^$' | tr '\n' ' '
}

cmd_status() {
  need_busctl

  local locale vconsole_keymap vconsole_toggle
  local x11_layout x11_model x11_variant x11_options

  locale=$(get_strarray Locale)
  vconsole_keymap=$(get_string VConsoleKeymap)
  vconsole_toggle=$(get_string VConsoleKeymapToggle)
  x11_layout=$(get_string X11Layout)
  x11_model=$(get_string X11Model)
  x11_variant=$(get_string X11Variant)
  x11_options=$(get_string X11Options)

  printf "   System Locale: %s\n"        "${locale:-n/a}"
       printf "       VC Keymap: %s\n"   "${vconsole_keymap:-n/a}"
  printf "      VC Toggle: %s\n"         "${vconsole_toggle:-(unset)}"
  printf "      X11 Layout: %s\n"        "${x11_layout:-n/a}"
  printf "       X11 Model: %s\n"        "${x11_model:-(unset)}"
  printf "     X11 Variant: %s\n"        "${x11_variant:-(unset)}"
  printf "     X11 Options: %s\n"        "${x11_options:-(unset)}"
}

cmd_set_locale() {
  need_busctl
  [ -z "$1" ] && die "set-locale: missing argument (e.g. LANG=en_US.UTF-8)"

  # build dbus array: as N val1 val2 ...
  local args=("$@")
  local count=${#args[@]}
  local dbus_args="$count"
  for a in "${args[@]}"; do
    dbus_args="$dbus_args \"$a\""
  done

  busctl call "$DBUS_DEST" "$DBUS_PATH" "$DBUS_IFACE" SetLocale asb $dbus_args false \
    || die "Failed to set locale"
}

cmd_set_keymap() {
  need_busctl
  [ -z "$1" ] && die "set-keymap: missing keymap argument"
  local keymap="$1"
  local toggle="${2:-}"
  busctl call "$DBUS_DEST" "$DBUS_PATH" "$DBUS_IFACE" SetVConsoleKeyboard ssbb \
    "$keymap" "$toggle" false false \
    || die "Failed to set keymap"
}

cmd_set_x11_keymap() {
  need_busctl
  [ -z "$1" ] && die "set-x11-keymap: missing layout argument"
  local layout="$1"
  local model="${2:-}"
  local variant="${3:-}"
  local options="${4:-}"
  busctl call "$DBUS_DEST" "$DBUS_PATH" "$DBUS_IFACE" SetX11Keyboard sssbb \
    "$layout" "$model" "$variant" "$options" false false \
    || die "Failed to set X11 keymap"
}

cmd_list_keymaps() {
  if [ -d /usr/share/keymaps ]; then
    find /usr/share/keymaps -name "*.map.gz" -o -name "*.map" \
      | xargs -I{} basename {} \
      | sed 's/\.map\.gz$//;s/\.map$//' \
      | sort
  elif [ -d /usr/share/kbd/keymaps ]; then
    find /usr/share/kbd/keymaps -name "*.map.gz" -o -name "*.map" \
      | xargs -I{} basename {} \
      | sed 's/\.map\.gz$//;s/\.map$//' \
      | sort
  else
    die "No keymap directory found"
  fi
}

cmd_list_locales() {
  if command -v locale &>/dev/null; then
    locale -a
  elif [ -f /etc/locale.gen ]; then
    grep -v '^#' /etc/locale.gen | grep -v '^$' | awk '{print $1}'
  else
    die "Cannot list locales"
  fi
}

usage() {
  cat <<EOF
Usage: localectl [OPTIONS] COMMAND

Commands:
  status                            Show current locale and keyboard settings
  set-locale LANG=xx [LC_*=xx ...]  Set system locale
  set-keymap KEYMAP [TOGGLE]        Set virtual console keyboard mapping
  set-x11-keymap LAYOUT [MODEL [VARIANT [OPTIONS]]]
                                    Set X11 keyboard mapping
  list-keymaps                      List available keymaps
  list-locales                      List available locales

Options:
  -h, --help                        Show this help
EOF
}

case "$1" in
  ""|status)        cmd_status ;;
  set-locale)       shift; cmd_set_locale "$@" ;;
  set-keymap)       cmd_set_keymap "$2" "$3" ;;
  set-x11-keymap)   cmd_set_x11_keymap "$2" "$3" "$4" "$5" ;;
  list-keymaps)     cmd_list_keymaps ;;
  list-locales)     cmd_list_locales ;;
  -h|--help)        usage ;;
  *)                die "Unknown command '$1'. Try --help." ;;
esac
